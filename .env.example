# ===== 数据库 =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kefu
POSTGRES_USER=kefu
POSTGRES_PASSWORD=kefu_secret_change_me

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== 服务 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8800
GUI_PORT=8801
DEBUG=true
LOG_LEVEL=INFO

# ===== 加密密钥 (用于加密存储在数据库中的 API Key) =====
# 首次启动会自动生成，也可手动设置
ENCRYPTION_KEY=change_this_to_random_32_bytes

# ===== 淘宝/抖音账号 (用于浏览器自动化) =====
TAOBAO_USERNAME=
TAOBAO_PASSWORD=
DOUYIN_USERNAME=
DOUYIN_PASSWORD=

# ===== 通知 =====
NOTIFY_WEBHOOK_URL=
NOTIFY_TYPE=telegram

# ===== 回复延迟 =====
AUTO_REPLY_DELAY_MIN=15
AUTO_REPLY_DELAY_MAX=60
